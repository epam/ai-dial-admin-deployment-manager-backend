{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/generate-db-schema.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./gradlew test --tests 'com.epam.aidial.deployment.manager.architecture.ArchitectureTest' -q 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
