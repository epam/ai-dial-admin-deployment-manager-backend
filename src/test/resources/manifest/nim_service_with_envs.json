{
  "apiVersion" : "apps.nvidia.com/v1alpha1",
  "kind" : "NIMService",
  "metadata" : {
    "annotations" : {
      "autoscaling.knative.dev/initial-scale" : "1",
      "autoscaling.knative.dev/min-scale" : "1",
      "autoscaling.knative.dev/max-scale" : "1",
      "serving.knative.dev/progress-deadline" : "3630s"
    },
    "name" : "dm-basic-nim-app"
  },
  "spec" : {
    "authSecret" : "ngc-api-secret",
    "env" : [ {
      "name" : "SIMPLE_VAR",
      "value" : "simple_value"
    }, {
      "name" : "SECRET_VAR",
      "valueFrom" : {
        "secretKeyRef" : {
          "key" : "secret-key",
          "name" : "my-secret"
        }
      }
    }, {
      "name" : "NIM_SERVED_MODEL_NAME",
      "value" : "basic-nim-app"
    } ],
    "expose" : {
      "router" : { },
      "service" : {
        "port" : 8000,
        "type" : "ClusterIP"
      }
    },
    "image" : {
      "pullPolicy" : "IfNotPresent",
      "pullSecrets" : [ "ngc-secret" ],
      "repository" : "my-registry.io/custom/my-model",
      "tag" : "v1.2.3"
    },
    "inferencePlatform" : "kserve",
    "replicas" : 1,
    "resources" : {
      "limits" : {
        "nvidia.com/gpu" : "1"
      },
      "requests" : { }
    },
    "storage" : {
      "pvc" : {
        "create" : true,
        "size" : "20Gi",
        "storageClass" : "default",
        "volumeAccessMode" : "ReadWriteOnce"
      }
    }
  }
}