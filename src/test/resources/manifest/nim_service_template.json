{
  "apiVersion": "apps.nvidia.com/v1alpha1",
  "kind": "NIMService",
  "spec": {
    "image": {
      "repository": "nvcr.io/nim/meta/llama-3.2-1b-instruct",
      "tag": "latest",
      "pullPolicy": "IfNotPresent",
      "pullSecrets": [
        "ngc-secret"
      ]
    },
    "authSecret": "ngc-api-secret",
    "replicas": 1,
    "storage": {
      "pvc": {
        "create": true,
        "storageClass": "default",
        "size": "20Gi",
        "volumeAccessMode": "ReadWriteOnce"
      }
    },
    "resources": {
      "limits": {
        "nvidia.com/gpu": "1"
      }
    },
    "expose": {
      "service": {
        "type": "ClusterIP",
        "port": 8000
      }
    }
  }
}
