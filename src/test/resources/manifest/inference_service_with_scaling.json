{
  "apiVersion": "serving.kserve.io/v1beta1",
  "kind": "InferenceService",
  "metadata": {
    "annotations": {
      "autoscaling.knative.dev/scale-to-zero-pod-retention-period": "600s",
      "autoscaling.knative.dev/initial-scale": "1"
    },
    "name": "dm-scaling-inference-app"
  },
  "spec": {
    "predictor": {
      "maxReplicas": 5,
      "minReplicas": 1,
      "model": {
        "args": [
          "--model_name",
          "scaling-inference-app"
        ],
        "env": [],
        "modelFormat": {
          "name": "huggingface"
        },
        "resources": {
          "limits": {},
          "requests": {}
        },
        "storageUri": "s3://my-bucket/scaling-model"
      },
      "scaleMetric": "concurrency",
      "scaleTarget": 10
    }
  }
}