{
  "$type": "inference",
  "name": "test-inference-deployment",
  "displayName": "Test Inference Deployment",
  "modelFormat": "huggingface",
  "source": {
    "$type": "huggingface",
    "modelName": "test-user/test-model"
  },
  "metadata": {
    "envs": []
  },
  "scaling": {
    "minReplicas": 1,
    "maxReplicas": 3,
    "strategy": {
      "$type": "hardware_usage",
      "threshold": 85
    }
  },
  "command": "python script.py --arg value",
  "args": "--config config.json --log-level DEBUG",
  "probeProperties": {
    "enabled": true,
    "initialDelaySeconds": 5,
    "periodSeconds": 10,
    "timeoutSeconds": 3,
    "failureThreshold": 2,
    "probe": {
      "$type": "httpGet",
      "path": "/health",
      "port": 8080
    }
  }
}
